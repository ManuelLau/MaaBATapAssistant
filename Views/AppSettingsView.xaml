<UserControl x:Class="MaaBATapAssistant.Views.AppSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:c="clr-namespace:CalcBinding;assembly=CalcBinding"
             xmlns:viewmodels="clr-namespace:MaaBATapAssistant.ViewModels"
             xmlns:utils="clr-namespace:MaaBATapAssistant.Utils"
             d:DataContext="{d:DesignInstance Type=viewmodels:SettingsViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">

    <Grid Margin="10 5 10 5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <hc:ScrollViewer Grid.Column="0" HorizontalAlignment="Stretch"
            HorizontalScrollBarVisibility="Disabled" IsInertiaEnabled="True"
            hc:ScrollViewerAttach.AutoHide="False">
            <StackPanel>
                <Grid Margin="0 10 0 0" HorizontalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="36"/>
                        <RowDefinition Height="36"/>
                        <RowDefinition Height="36"/>
                        <RowDefinition Height="64"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="模拟器/PC端路径" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Button Content="选择" Width="56" Height="32" Margin="8 0 0 0"
                                Command="{Binding SelectDevicePathCommand}"/>
                    </StackPanel>
                    <TextBox Grid.Row="1" Text="{Binding ProgramData.SettingsData.DevicePath}" Width="400" Height="32"
                             TextChanged="DevicePathTextBoxTextChanged"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="等待模拟器/PC端启动时间（秒）" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding ProgramData.SettingsData.AutoRunDeviceWaittingTimeSpan}" Width="36" Height="32" Margin="4 0 0 0"
                                 HorizontalContentAlignment="Center"
                                 PreviewTextInput="AutoRunDeviceWaittingTimeSpanTextBoxPreviewTextInput"
                                 TextChanged="AutoRunDeviceWaittingTimeSpanTextBoxTextChanged"
                                 LostFocus="AutoRunDeviceWaittingTimeSpanTextBoxLostFocus"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0 0 0 0" HorizontalAlignment="Center">
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                            <hc:Shield Subject="软件版本" Margin="0 4 0 4" Status="{x:Static utils:Constants.AppVersion}" HorizontalAlignment="Center"/>
                            <hc:Shield Subject="资源版本" Margin="0 4 0 4" Status="{Binding ProgramData.ResourcesVersion}" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                            <Button Content="检查更新" Width="80" Height="36" Margin="16 0 0 0"
                                    Command="{Binding OpenUpdateWindowCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <hc:Divider Content="关于" Margin="100 10 100 10"/>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition Height="30"/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Content="查看公告" Width="80" Height="36" Margin="0 0 0 10"
                            Command="{Binding OpenAnnouncementWindowCommand}"/>
                    <TextBlock Grid.Row="1" HorizontalAlignment="Center" Text="B站主页" Foreground="Blue" Cursor="Hand"
                               MouseDown="BilibiliLinkMouseDown"/>
                    <hc:Shield Grid.Row="2" Subject="GitHub" Status="MaaBATapAssistant" Margin="0 0 0 10"
                               VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalAlignment="Center"
                               Command="hc:ControlCommands.OpenLink" CommandParameter="{x:Static utils:Constants.ProjectGitHubUrl}"/>
                    <hc:Shield Grid.Row="3" Subject="Gitee" Status="MaaBATapAssistant" 
                               VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalAlignment="Center"
                               Command="hc:ControlCommands.OpenLink" CommandParameter="{x:Static utils:Constants.ProjectGiteeUrl}"/>
                </Grid>
            </StackPanel>
        </hc:ScrollViewer>
    </Grid>
</UserControl>